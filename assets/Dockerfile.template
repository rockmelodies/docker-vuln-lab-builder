# =============================================================================
# Docker 漏洞靶场 Dockerfile 模板
# 使用说明: 根据具体漏洞场景修改以下配置
# =============================================================================

# -------------------------------------------------------------------------
# 1. 基础镜像 - 必须指定明确版本标签，禁止使用 latest
# -------------------------------------------------------------------------
# Web应用示例:
# FROM php:8.1-apache
# FROM python:3.10-slim
# FROM node:18-alpine
# FROM openjdk:11-jdk-slim
#
# 数据库示例:
# FROM mysql:8.0
# FROM postgres:15
# FROM redis:7.0
#
# 系统示例:
# FROM ubuntu:22.04
# FROM debian:bullseye
# FROM alpine:3.18

FROM ubuntu:22.04

# -------------------------------------------------------------------------
# 2. 元数据标签
# -------------------------------------------------------------------------
LABEL maintainer="security-lab"
LABEL description="漏洞靶场 - [漏洞名称]"
LABEL vuln.type="[漏洞类型]"
LABEL vuln.cve="[CVE编号]"
LABEL vuln.difficulty="[难度等级]"

# -------------------------------------------------------------------------
# 3. 环境变量 - 避免硬编码敏感信息
# -------------------------------------------------------------------------
ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
# ENV DB_PASSWORD=  # 通过运行时环境变量传入
# ENV SECRET_KEY=   # 通过运行时环境变量传入

# -------------------------------------------------------------------------
# 4. 安装依赖 - 合并RUN指令减少镜像层
# -------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    # 基础工具
    curl \
    wget \
    net-tools \
    # 应用依赖
    # [根据实际需求添加]
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# -------------------------------------------------------------------------
# 5. 创建非root用户 (如应用允许)
# -------------------------------------------------------------------------
# RUN groupadd -r appuser && useradd -r -g appuser -d /home/appuser -s /sbin/nologin appuser

# -------------------------------------------------------------------------
# 6. 复制应用代码
# -------------------------------------------------------------------------
WORKDIR /app
COPY . /app/

# -------------------------------------------------------------------------
# 7. 设置文件权限
# -------------------------------------------------------------------------
# RUN chown -R appuser:appuser /app
# RUN chmod +x /app/entrypoint.sh

# -------------------------------------------------------------------------
# 8. 切换到非root用户
# -------------------------------------------------------------------------
# USER appuser

# -------------------------------------------------------------------------
# 9. 暴露端口
# -------------------------------------------------------------------------
EXPOSE 80

# -------------------------------------------------------------------------
# 10. 健康检查
# -------------------------------------------------------------------------
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:80/ || exit 1

# -------------------------------------------------------------------------
# 11. 启动命令
# -------------------------------------------------------------------------
# 使用entrypoint脚本处理初始化逻辑
# COPY entrypoint.sh /entrypoint.sh
# ENTRYPOINT ["/entrypoint.sh"]

# 或直接启动
CMD ["python3", "-m", "http.server", "80"]
